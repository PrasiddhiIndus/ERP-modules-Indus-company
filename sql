  -- Create moc_prices table with BIGINT tender_id
CREATE TABLE IF NOT EXISTS moc_prices (
    id uuid PRIMARY KEY DEFAULT gen_random_uuid(),
    tender_id bigint NOT NULL REFERENCES tenders(id) ON DELETE CASCADE,
    moc text NOT NULL,
    unit text NOT NULL,
    price numeric,
    inserted_at timestamp with time zone DEFAULT now(),
    updated_at timestamp with time zone DEFAULT now()
);

-- Ensure each MOC is unique per tender
CREATE UNIQUE INDEX IF NOT EXISTS unique_moc_per_tender
ON moc_prices(moc, tender_id);


