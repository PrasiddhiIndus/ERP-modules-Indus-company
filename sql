-- Table: manpower_enquiries
create table if not exists public.manpower_enquiries (
    id uuid default gen_random_uuid() primary key,
    client text not null,
    phone text,
    email text,
    street text,
    street2 text,
    city text,
    state text,
    zip text,
    country text,
    priority int default 1,
    source text default 'Mail',
    due_date date,
    rfq_available boolean default false,
    project_estimation text,
    duration jsonb, -- { days, months, years }
    documents text, -- store file url/path from Supabase Storage
    manpower_required text,
    fire_tender_required boolean default false,
    contacts jsonb, -- array of contact objects
    handled_by text,
    authorization_to text,
    enquiry_number text,
    status text default 'Pending',
    user_id uuid references auth.users(id), -- 🔑 link to Supabase Auth user
    created_at timestamptz default now(),
    updated_at timestamptz default now()
);

-- Enable Row Level Security
alter table public.manpower_enquiries enable row level security;

-- INSERT: Users can insert their own enquiries
create policy "Users can insert their own enquiries"
on public.manpower_enquiries
for insert
with check (auth.uid() = user_id);

-- SELECT: Users can view their own enquiries
create policy "Users can view their own enquiries"
on public.manpower_enquiries
for select
using (auth.uid() = user_id);

-- UPDATE: Users can update their own enquiries
create policy "Users can update their own enquiries"
on public.manpower_enquiries
for update
using (auth.uid() = user_id);

-- DELETE: Users can delete their own enquiries
create policy "Users can delete their own enquiries"
on public.manpower_enquiries
for delete
