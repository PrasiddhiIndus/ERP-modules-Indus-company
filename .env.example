# Production — copy to `.env.production` for builds, or to `.env` for local dev against production DB.
# Never commit `.env` / `.env.production`. Staging template: `.env.staging.example` → `.env.staging`
# Get URL + anon key from Supabase Dashboard → Project Settings → API (anon/public only, not service_role).

VITE_SUPABASE_URL=https://wbyzhknaqcjqqtwopupl.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6IndieXpoa25hcWNqcXF0d29wdXBsIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NTcwNTk2MzYsImV4cCI6MjA3MjYzNTYzNn0.9ZjTRFuh2DTQ7vU_X7FvX-XKPQJJ8z8XbVip5R69gT4

# Optional: set to true if WebSocket/realtime fails (firewall/VPN). Fleet and other data still load via REST.
# VITE_DISABLE_SUPABASE_REALTIME=true

# E-Invoice provider: keep backend for secure production
VITE_EINVOICE_PROVIDER=backend

# Frontend calls backend proxy route. Relative paths use VITE_API_BASE_URL when it is set.
VITE_EINVOICE_API_URL=/api/billing/e-invoice

# Node API (attendance / eTimeOffice sync, R2 uploads, e-invoice): run `npm run dev` (Vite + server) or `npm run server`.
# Dev: leave unset — browser calls /api and Vite proxies to port 8787 (see vite.config.ts).
# Production static host: set to your deployed Node origin (e.g. Render URL from render.yaml):
# VITE_API_BASE_URL=https://your-erp-api.onrender.com

# For Whitebooks secrets, use .env.server (see .env.server.example)