# Server-side env only — copy to `.env.server` on the machine running `server/index.js`.
# Do NOT prefix with VITE_ (those are exposed in the browser bundle).

SERVER_PORT=8787

# Production Whitebooks API (see developer.whitebooks.in — POST GENERATE V1_03)
WHITEBOOKS_BASE_URL=https://api.whitebooks.in

# Email registered with Whitebooks (passed as ?email= on authenticate & generate)
WHITEBOOKS_EMAIL=your-registered@email.com

# API credentials from Whitebooks Developer Portal → Credentials / Auth Keys
WHITEBOOKS_USERNAME=
WHITEBOOKS_PASSWORD=
WHITEBOOKS_IP_ADDRESS=0.0.0.0
WHITEBOOKS_CLIENT_ID=
WHITEBOOKS_CLIENT_SECRET=

# Supplier GSTIN linked to the Whitebooks account
WHITEBOOKS_GSTIN=24XXXXXXXXXXXXX

# Optional PIN fallbacks for buyer (state/pin consistency)
# WHITEBOOKS_FALLBACK_BUYER_PIN=391740
# WHITEBOOKS_FALLBACK_BUYER_PIN_STATE_24=391740
