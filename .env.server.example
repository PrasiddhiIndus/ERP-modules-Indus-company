# --- Cloudflare R2 (Software subscriptions invoice uploads only) ---
# S3 API endpoint from R2 dashboard (https://<account_id>.r2.cloudflarestorage.com)
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=indus-erp-uploads
# Optional: omit R2_BUCKET to use default indus-erp-uploads. "Folders" in R2 are key prefixes (e.g. software-subscriptions/), not separate buckets.
# Uploads go browser -> Node -> R2 (no R2 CORS needed for PUT). For presigned GET opens, add R2 CORS if the browser blocks the download tab.

