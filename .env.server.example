# Server-only eTimeOffice credentials (DO NOT expose to frontend)
ETIME_BASE_URL=https://api.etimeoffice.com/api
ETIME_PUNCH_ENDPOINT=DownloadInOutPunchData
ETIME_AUTH_CREDENTIALS=INDUSFIRESAFETY:INDUSFIRESAFETY:iNDIA@1234:true
ETIME_TIMEOUT_MS=60000
# Merge DownloadPunchData + DownloadInOutPunchData (recommended: true)
ETIME_MERGE_PUNCH_ENDPOINTS=true
# Prefer per-punch endpoint first when ETIME_PREFER_GRANULAR_PUNCHES=true
# ETIME_PREFER_GRANULAR_PUNCHES=false
# Overlap sync (POST /api/admin/attendance/sync and optional cron)
ETIME_SYNC_OVERLAP_HOURS=24
ETIME_SYNC_LOOKBACK_DAYS=14
ETIME_SYNC_TIMEZONE=Asia/Kolkata
ETIME_MAX_DAYS_PER_REQUEST=7
# Optional: ETIME_SYNC_SECRET=change-me  (header x-etime-sync-secret)
# ETIME_SYNC_CRON_ENABLED=true
# ETIME_SYNC_INTERVAL_MS=900000

