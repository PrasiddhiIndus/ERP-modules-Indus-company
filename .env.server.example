# Server-side env only — load from `.env.server` (see your API worker / proxy).
# Do NOT prefix with VITE_ (those are exposed in the browser bundle).
# Replace every value below; never commit real secrets.

SERVER_PORT=8787
WHITEBOOKS_BASE_URL=https://api.whitebooks.in
WHITEBOOKS_EMAIL=your_api_account@example.com
WHITEBOOKS_USERNAME=your_username
WHITEBOOKS_PASSWORD=your_password
WHITEBOOKS_IP_ADDRESS=0.0.0.0
WHITEBOOKS_CLIENT_ID=your_client_id
WHITEBOOKS_CLIENT_SECRET=your_client_secret
WHITEBOOKS_GSTIN=your_15_char_gstin
WHITEBOOKS_FALLBACK_BUYER_PIN=
WHITEBOOKS_FALLBACK_BUYER_PIN_STATE_24=
