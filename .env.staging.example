VITE_EINVOICE_PROVIDER=backend

# Frontend calls backend proxy route. Relative paths use VITE_API_BASE_URL when it is set.
VITE_EINVOICE_API_URL=/api/billing/e-invoice

# Dev: leave unset — Vite proxies /api to port 8787 (see vite.config.ts).
# Staging droplet (nginx :3001 → API :4001): leave unset; /api is proxied by nginx.

# Server (PM2 on droplet): copy .env.server.example → .env.server in /root/indus-erp-staging
# Set SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY to staging project, SERVER_PORT=4001
