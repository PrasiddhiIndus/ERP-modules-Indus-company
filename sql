-- Table for Main Components & Sub Categories
create table main_components (
  id bigint generated by default as identity primary key,
  main_component text not null,
  sub_category1 text,
  sub_category2 text,
  sub_category3 text,
  sub_category4 text,
  sub_category5 text,
  created_at timestamptz default now(),
  user_id uuid references auth.users(id) -- 🔑 link to Supabase Auth user
);
alter table main_components enable row level security;

-- Allow INSERT only for logged-in users (their user_id must match)
create policy "Users can insert their own data"
on main_components for insert
with check (auth.uid() = user_id);

-- Allow SELECT only their own rows
create policy "Users can view their own data"
on main_components for select
using (auth.uid() = user_id);

-- Allow UPDATE only their own rows
create policy "Users can update their own data"
on main_components for update
using (auth.uid() = user_id);

-- Allow DELETE only their own rows
create policy "Users can delete their own data"
on main_components for delete
using (auth.uid() = user_id);


-- Table for Tenders
create table tenders (
  id bigint generated by default as identity primary key,
  client text,
  phone text,
  email text,
  street text,
  street2 text,
  zip text,
  city text,
  state text,
  country text,
  source text,
  type_of_tender text,
  mode_of_tender text,
  vehicle_type text,
  tender_id_available boolean,
  publish_date date,
  due_date date,
  estimation text,
  description text,
  handled_by text,
  authorization_to text,
  status text,
  tender_number text,
  created_at timestamp default now(),
  updated_at timestamp default now(),
  enquiry_number text,
  user_id uuid references auth.users(id) -- 🔑 link to Supabase Auth user
);

-- Enable Row Level Security
alter table tenders enable row level security;

-- Allow INSERT only for logged-in users (must insert their own user_id)
create policy "Users can insert their own tenders"
on tenders for insert
with check (auth.uid() = user_id);

-- Allow SELECT only their own tenders
create policy "Users can view their own tenders"
on tenders for select
using (auth.uid() = user_id);

-- Allow UPDATE only their own tenders
create policy "Users can update their own tenders"
on tenders for update
using (auth.uid() = user_id);

-- Allow DELETE only their own tenders
create policy "Users can delete their own tenders"
on tenders for delete
using (auth.uid() = user_id);


