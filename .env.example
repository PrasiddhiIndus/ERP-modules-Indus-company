# Copy to `.env` and fill in values. Never commit `.env`.
# Get URL + anon key from Supabase Dashboard → Project Settings → API (use "anon" / "public", not service_role).

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Local dev: Vite proxies /api → localhost (see vite.config.ts).
# Production: full URL of your deployed backend API, no trailing slash:
# VITE_EINVOICE_API_URL=https://your-api.onrender.com/api/billing/e-invoice
# E-invoice: prefer backend proxy in production so Whitebooks secrets stay server-side only.
VITE_EINVOICE_PROVIDER=backend
VITE_EINVOICE_API_URL=/api/billing/e-invoice

# For Whitebooks secrets, use .env.server on the API server only (see .env.server.example).
